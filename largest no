import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner s=new Scanner(System.in);
        System.out.println("Enter the value of n");
        int n=s.nextInt();
        int num=n;
        int lar=0;
        int d=n%10;
        if(d>lar)
        {
            lar=d;
            System.out.println("The largest number is"+lar);
        }
        n=n/10;
    }
}
